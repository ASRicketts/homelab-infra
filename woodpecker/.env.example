# Woodpecker secrets. Copy to .env and fill in real values.
# .env is gitignored.

# From Gitea: Site Administration > Applications > Create New Application
WOODPECKER_GITEA_CLIENT=gitea client ID goes here
WOODPECKER_GITEA_SECRET=gitea oauth client secret goes here

# Shared secret between Woodpecker server and agent.
# Generate with openssl rand -hex 32
WOODPECKER_AGENT_SECRET=use a strong password 